{
  "manifest_version": 3,
  "name": "YouTube Live Translator",
  "description": "YouTube live and recorded video subtitles with multi-model AI API, Ollama, and LM Studio translation.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "YouTube Live Translator",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "offscreen",
    "scripting",
    "storage",
    "tabCapture",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://api.openai.com/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.openai.com https: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*;"
  }
}
