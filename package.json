{
  "name": "youtube-live-translator-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "stt:setup": "uv python install 3.11 && uv venv --python 3.11 .venv-stt && uv pip install --python .venv-stt/Scripts/python.exe -r local_stt/requirements.txt",
    "stt:start": ".\\.venv-stt\\Scripts\\python.exe -m uvicorn local_stt.app:app --host 127.0.0.1 --port 8765",
    "stt:daemon": ".\\.venv-stt\\Scripts\\python.exe local_stt/start_server.py",
    "stt:dev": ".\\.venv-stt\\Scripts\\python.exe -m uvicorn local_stt.app:app --host 127.0.0.1 --port 8765",
    "stt:health": ".\\.venv-stt\\Scripts\\python.exe local_stt/health_check.py"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
